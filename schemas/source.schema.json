{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/axm-capability-claim-test/source.schema.json",
  "title": "Source",
  "type": "object",
  "required": ["id", "title"],
  "properties": {
    "id": { "type": "string", "description": "Local id referenced by claims." },
    "title": { "type": "string" },
    "url": { "type": "string" },
    "publisher": { "type": "string" },
    "date": { "type": "string", "description": "ISO 8601 where known." },
    "note": { "type": "string" }
  },
  "additionalProperties": false
}
